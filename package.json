{
  "name": "vscode-config",
  "version": "1.0.0",
  "description": "VS Code config portable: settings, extensiones y atajos Vim, con backup automático y restore.",
  "bin": {
    "vscode-config": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "setup.sh",
    "setup.ps1",
    "restore.sh",
    "restore.ps1",
    "settings.json",
    "extensions.txt",
    "fire code font/",
    "README.md",
    ".gitignore"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codexyzdev/vscode-config.git"
  },
  "keywords": ["vscode", "vim", "config", "setup", "restore"],
  "license": "MIT",
  "engines": {
    "node": ">=14"
  }
}
